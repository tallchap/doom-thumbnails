# Ignore everything by default
*

# Core app files
!.gitignore
!app.py
!config.py
!auth.py
!requirements.txt
!Procfile
!render.yaml
!deploy-cloudrun.sh

# Modular Flask structure
!shared/
!shared/**
!thumbnails/
!thumbnails/**
!revision/
!revision/**
!descriptions/
!descriptions/**
!face_capture/
!face_capture/**

# Ignore compiled Python files within tracked dirs
__pycache__/
*.pyc

# Reference images & assets
!doom_debates_thumbnails/
!doom_debates_thumbnails/**
!liron_reactions/
!liron_reactions/**
!assets/
!assets/**

# Docs
!FACE_CAPTURE_CONTEXT.md

# Format app (Next.js sub-service)
!format-app/
!format-app/**
.gstack/
